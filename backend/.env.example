# Quixora Billing Engine - Environment Variables
# Copy this file to .env and fill in the real values.

# Database Configuration
# For local SQLite development, leave DATABASE_URL commented out.
# For production (Supabase/Neon), provide the full connection string.
# DATABASE_URL=postgres://user:password@hostname:5432/dbname

# Server Configuration
PORT=3000
NODE_ENV=development

# Third-party Integrations (Optional for now)
# WHATSAPP_API_TOKEN=your_token_here
# MPESA_SHORTCODE=your_shortcode_here
